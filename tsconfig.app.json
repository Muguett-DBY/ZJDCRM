{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"]
  },
  "include": [
    "src",
    "server",
    "worker-configuration.d.ts",
    "tests/unit/**/*.ts",
    "tests/unit/**/*.tsx",
    "tests/components/**/*.ts",
    "tests/components/**/*.tsx"
  ]
}
